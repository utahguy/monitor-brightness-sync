#!/usr/bin/env bash
#
# monitor-brightness-sync — Sync laptop brightness keys to external monitors via DDC/CI
#
# Dependencies: ddcutil, inotify-tools
# Install:      sudo apt install ddcutil inotify-tools
#
# Usage:        monitor-brightness-sync [--once] [--dry-run]
#   --once      Apply current brightness and exit (no daemon loop)
#   --dry-run   Print what would happen without changing anything

set -euo pipefail

# --- Configuration -----------------------------------------------------------
# DDC/CI brightness VCP code
VCP_BRIGHTNESS=0x10

# Default VCP range for uncalibrated monitors (standard DDC/CI)
DEFAULT_MIN_VCP=0
DEFAULT_MAX_VCP=100

# Seconds to cache the monitor detection result
MONITOR_CACHE_TTL=60

# Per-monitor calibration config file
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/monitor-brightness-sync"
CONFIG_FILE="${CONFIG_DIR}/monitors.conf"

# Path to ddcutil (hardcoded to prevent command injection via environment)
DDCUTIL="ddcutil"

# --- Globals -----------------------------------------------------------------
BACKLIGHT_DIR=""
BACKLIGHT_MAX=""
MONITOR_BUSES=()
MONITOR_IDS=()
MONITOR_CACHE_TIME=0
DRY_RUN=false
ONCE=false
CALIBRATE=false

# Associative arrays for per-monitor VCP ranges (keyed by monitor ID)
declare -A MONITOR_MIN_VCP
declare -A MONITOR_MAX_VCP

# --- Functions ---------------------------------------------------------------

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

die() {
    log "ERROR: $*" >&2
    exit 1
}

check_deps() {
    for cmd in "$DDCUTIL" inotifywait; do
        if ! command -v "$cmd" &>/dev/null; then
            die "'$cmd' not found. Install with: sudo apt install ${cmd/ddcutil/ddcutil}${cmd/inotifywait/inotify-tools}"
        fi
    done
}

load_monitor_config() {
    [[ -f "$CONFIG_FILE" ]] || return 0
    while IFS= read -r line; do
        # Skip comments and blank lines
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// /}" ]] && continue
        local id min_vcp max_vcp
        read -r id min_vcp max_vcp <<< "$line"
        if [[ -n "$id" && -n "$min_vcp" && -n "$max_vcp" ]]; then
            MONITOR_MIN_VCP["$id"]=$min_vcp
            MONITOR_MAX_VCP["$id"]=$max_vcp
        fi
    done < "$CONFIG_FILE"
}

save_monitor_config() {
    local id=$1 min_vcp=$2 max_vcp=$3
    mkdir -p "$CONFIG_DIR"
    # Remove existing entry for this monitor if present
    if [[ -f "$CONFIG_FILE" ]]; then
        local tmp
        tmp=$(grep -v "^${id} " "$CONFIG_FILE" 2>/dev/null) || true
        echo "$tmp" > "$CONFIG_FILE"
    fi
    # Append new entry
    echo "${id} ${min_vcp} ${max_vcp}" >> "$CONFIG_FILE"
    # Update in-memory state
    MONITOR_MIN_VCP["$id"]=$min_vcp
    MONITOR_MAX_VCP["$id"]=$max_vcp
    log "Saved calibration for ${id}: min_vcp=${min_vcp} max_vcp=${max_vcp}"
}

get_monitor_vcp_range() {
    local id=$1
    local min_vcp=${MONITOR_MIN_VCP["$id"]:-$DEFAULT_MIN_VCP}
    local max_vcp=${MONITOR_MAX_VCP["$id"]:-$DEFAULT_MAX_VCP}
    echo "$min_vcp $max_vcp"
}

scale_brightness() {
    local pct=$1 min_vcp=$2 max_vcp=$3
    # Scale laptop 0-100% to min_vcp-max_vcp range
    echo $(( min_vcp + (max_vcp - min_vcp) * pct / 100 ))
}

find_backlight() {
    local dir
    for dir in /sys/class/backlight/*/; do
        if [[ -f "${dir}brightness" && -f "${dir}max_brightness" ]]; then
            BACKLIGHT_DIR="$dir"
            BACKLIGHT_MAX=$(cat "${dir}max_brightness")
            log "Backlight: ${dir} (max=${BACKLIGHT_MAX})"
            return 0
        fi
    done
    die "No backlight device found in /sys/class/backlight/"
}

detect_monitors() {
    local now
    now=$(date +%s)

    # Use cached result if fresh enough
    if (( ${#MONITOR_BUSES[@]} > 0 && now - MONITOR_CACHE_TIME < MONITOR_CACHE_TTL )); then
        return 0
    fi

    MONITOR_BUSES=()
    MONITOR_IDS=()
    MONITOR_CACHE_TIME=$now

    log "Detecting external monitors..."

    # ddcutil detect lists monitors with their I2C bus numbers and identifiers
    local detect_output
    detect_output=$("$DDCUTIL" detect --terse 2>/dev/null) || true

    # Parse bus numbers and monitor IDs from detect output
    local candidate_buses=() candidate_ids=()
    local current_bus="" current_id=""
    while IFS= read -r line; do
        if [[ "$line" =~ I2C\ bus:.*i2c-([0-9]+) ]]; then
            current_bus="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ Monitor:\ +(.+) ]]; then
            current_id="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^$ && -n "$current_bus" ]]; then
            # End of a display block
            if [[ -n "$current_id" ]]; then
                candidate_buses+=("$current_bus")
                candidate_ids+=("$current_id")
            fi
            current_bus=""
            current_id=""
        fi
    done <<< "$detect_output"
    # Capture last block
    if [[ -n "$current_bus" && -n "$current_id" ]]; then
        candidate_buses+=("$current_bus")
        candidate_ids+=("$current_id")
    fi

    # Verify each candidate supports DDC/CI read AND write for brightness
    local i
    for i in "${!candidate_buses[@]}"; do
        local bus="${candidate_buses[$i]}"
        local id="${candidate_ids[$i]}"
        local cur_val
        cur_val=$("$DDCUTIL" getvcp "$VCP_BRIGHTNESS" --bus "$bus" --terse 2>/dev/null) || {
            log "Skipping bus i2c-${bus} (DDC/CI read failed)"
            continue
        }
        # --terse output: "VCP 10 C 35 100" — current value is field 4
        local cur_pct
        cur_pct=$(echo "$cur_val" | awk '{print $4}')
        if [[ -z "$cur_pct" ]]; then
            log "Skipping bus i2c-${bus} (unexpected getvcp output)"
            continue
        fi
        # Write back the same value to verify write path works
        if ! "$DDCUTIL" setvcp "$VCP_BRIGHTNESS" "$cur_pct" --bus "$bus" --noverify 2>/dev/null; then
            log "Skipping bus i2c-${bus} (DDC/CI write failed)"
            continue
        fi
        MONITOR_BUSES+=("$bus")
        MONITOR_IDS+=("$id")
    done

    if (( ${#MONITOR_BUSES[@]} == 0 )); then
        log "No external DDC/CI monitors detected"
    else
        log "Found ${#MONITOR_BUSES[@]} external monitor(s) on bus(es): ${MONITOR_BUSES[*]}"
    fi
}

get_laptop_brightness_pct() {
    local cur
    cur=$(cat "${BACKLIGHT_DIR}brightness")
    echo $(( cur * 100 / BACKLIGHT_MAX ))
}

set_monitor_brightness() {
    local laptop_pct=$1

    detect_monitors

    if (( ${#MONITOR_BUSES[@]} == 0 )); then
        return 0
    fi

    local i
    for i in "${!MONITOR_BUSES[@]}"; do
        local bus="${MONITOR_BUSES[$i]}"
        local id="${MONITOR_IDS[$i]}"
        local min_vcp max_vcp vcp_val
        read -r min_vcp max_vcp <<< "$(get_monitor_vcp_range "$id")"
        vcp_val=$(scale_brightness "$laptop_pct" "$min_vcp" "$max_vcp")

        if $DRY_RUN; then
            log "[dry-run] Would set ${id} (bus i2c-${bus}) VCP to ${vcp_val} (laptop ${laptop_pct}%, range ${min_vcp}-${max_vcp})"
        else
            log "Setting ${id} (bus i2c-${bus}) VCP to ${vcp_val} (laptop ${laptop_pct}%)"
            if ! "$DDCUTIL" setvcp "$VCP_BRIGHTNESS" "$vcp_val" --bus "$bus" --noverify 2>/dev/null; then
                # DDC/CI can be flaky — retry once after a brief pause
                sleep 0.2
                "$DDCUTIL" setvcp "$VCP_BRIGHTNESS" "$vcp_val" --bus "$bus" --noverify 2>/dev/null \
                    || log "WARNING: Failed to set brightness on bus i2c-${bus}"
            fi
            # Brief pause between monitors to avoid I2C bus contention
            sleep 0.1
        fi
    done
}

sync_brightness() {
    local pct
    pct=$(get_laptop_brightness_pct)
    log "Laptop brightness: ${pct}%"
    set_monitor_brightness "$pct"
}

calibrate_monitor() {
    local bus=$1 id=$2

    echo ""
    echo "=== Calibrating: ${id} (bus i2c-${bus}) ==="
    echo "This will set VCP brightness values and ask you to read the monitor's OSD."
    echo "Use the monitor's physical brightness button to bring up the OSD after each step."
    echo ""

    # Find max_vcp: the VCP value where OSD reads 100
    echo "--- Finding maximum VCP (OSD = 100) ---"
    local lo=0 hi=100 mid osd_val
    while (( hi - lo > 1 )); do
        mid=$(( (lo + hi) / 2 ))
        "$DDCUTIL" setvcp "$VCP_BRIGHTNESS" "$mid" --bus "$bus" --noverify &>/dev/null
        sleep 1
        echo ""
        read -rp "VCP set to ${mid}. What does the monitor OSD show? " osd_val
        if (( osd_val >= 100 )); then
            hi=$mid
        else
            lo=$mid
        fi
    done
    # Verify hi gives OSD >= 100
    "$DDCUTIL" setvcp "$VCP_BRIGHTNESS" "$hi" --bus "$bus" --noverify &>/dev/null
    sleep 1
    echo ""
    read -rp "VCP set to ${hi}. What does the OSD show? (should be ~100) " osd_val
    local max_vcp=$hi
    if (( osd_val < 100 )); then
        echo "OSD still below 100 at VCP ${hi}. Using VCP 100 as max."
        max_vcp=100
    fi
    echo "Max VCP: ${max_vcp}"

    # Find min_vcp: the VCP value where OSD reads 0
    echo ""
    echo "--- Finding minimum VCP (OSD = 0) ---"
    "$DDCUTIL" setvcp "$VCP_BRIGHTNESS" 0 --bus "$bus" --noverify &>/dev/null
    sleep 1
    echo ""
    read -rp "VCP set to 0. What does the monitor OSD show? " osd_val
    local min_vcp=0
    if (( osd_val <= 0 )); then
        echo "Min VCP: 0"
    else
        echo "OSD shows ${osd_val} at VCP 0. Monitor floor is above 0 — using VCP 0 as min."
        echo "(The monitor cannot go dimmer than this via DDC/CI.)"
        min_vcp=0
    fi

    # Restore to a comfortable brightness
    local restore=$(( max_vcp / 2 ))
    "$DDCUTIL" setvcp "$VCP_BRIGHTNESS" "$restore" --bus "$bus" --noverify &>/dev/null

    echo ""
    echo "Calibration result: ${id} — VCP range ${min_vcp}-${max_vcp}"
    read -rp "Save this calibration? [Y/n] " confirm
    if [[ "${confirm,,}" != "n" ]]; then
        save_monitor_config "$id" "$min_vcp" "$max_vcp"
    else
        echo "Calibration discarded."
    fi
}

run_calibration() {
    check_deps
    load_monitor_config

    # Force fresh detection
    MONITOR_CACHE_TIME=0
    detect_monitors

    if (( ${#MONITOR_BUSES[@]} == 0 )); then
        die "No external monitors detected. Cannot calibrate."
    fi

    echo "Detected ${#MONITOR_BUSES[@]} monitor(s):"
    local i
    for i in "${!MONITOR_BUSES[@]}"; do
        local id="${MONITOR_IDS[$i]}"
        local status="uncalibrated"
        if [[ -n "${MONITOR_MAX_VCP[$id]:-}" ]]; then
            status="calibrated (VCP ${MONITOR_MIN_VCP[$id]}-${MONITOR_MAX_VCP[$id]})"
        fi
        echo "  ${i}: ${id} (bus i2c-${MONITOR_BUSES[$i]}) — ${status}"
    done

    for i in "${!MONITOR_BUSES[@]}"; do
        local id="${MONITOR_IDS[$i]}"
        if [[ -n "${MONITOR_MAX_VCP[$id]:-}" ]]; then
            read -rp "Re-calibrate ${id}? [y/N] " recal
            [[ "${recal,,}" == "y" ]] || continue
        fi
        calibrate_monitor "${MONITOR_BUSES[$i]}" "$id"
    done

    echo ""
    echo "Calibration complete. Config saved to: ${CONFIG_FILE}"
}

run_daemon() {
    log "Starting brightness sync daemon"
    log "Watching: ${BACKLIGHT_DIR}brightness"

    # Initial sync
    sync_brightness

    # Watch for brightness file changes (written by the kernel on key press)
    inotifywait -m -e modify "${BACKLIGHT_DIR}brightness" --format '%e' 2>/dev/null |
    while read -r _event; do
        # Coalesce rapid events (holding the key down)
        sleep 0.05
        # Drain any queued events
        while read -r -t 0.01 _; do :; done
        sync_brightness
    done
}

cleanup() {
    log "Shutting down"
    # Kill any lingering ddcutil processes we spawned
    jobs -p | xargs -r kill 2>/dev/null || true
    exit 0
}

# --- Main --------------------------------------------------------------------

main() {
    while (( $# > 0 )); do
        case "$1" in
            --once)      ONCE=true ;;
            --dry-run)   DRY_RUN=true ;;
            --calibrate) CALIBRATE=true ;;
            --help|-h)
                echo "Usage: $(basename "$0") [--once] [--dry-run] [--calibrate]"
                echo ""
                echo "Syncs laptop brightness to external monitors via DDC/CI."
                echo ""
                echo "Options:"
                echo "  --once        Apply current brightness and exit"
                echo "  --dry-run     Print actions without changing monitor brightness"
                echo "  --calibrate   Interactively calibrate VCP range for connected monitors"
                echo "  -h, --help    Show this help"
                exit 0
                ;;
            *) die "Unknown option: $1" ;;
        esac
        shift
    done

    if $CALIBRATE; then
        run_calibration
        exit 0
    fi

    check_deps
    find_backlight
    load_monitor_config

    if $ONCE; then
        sync_brightness
    else
        trap cleanup SIGINT SIGTERM
        run_daemon
    fi
}

main "$@"
